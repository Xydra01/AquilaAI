SMTP_SERVER=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=

# Ollama — stock portable on 11434 (see docs/ollama-dual-setup.md)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=aquila_heretic

# TurboQuant optional (PR #15505 on 11435 — see docs/ollama-turboquant.md)
# OLLAMA_BASE_URL=http://127.0.0.1:11435
# OLLAMA_MODEL=aquila-tq-32k   # light tasks, lowest VRAM (~same ctx as aquila)
# OLLAMA_MODEL=aquila-tq-64k   # recommended extended context
# OLLAMA_MODEL=aquila-tq-96k   # max context if VRAM allows
# Optional without recreating model: OLLAMA_NUM_CTX=32768
# Keep model loaded between requests (helps long agent runs / live tests): OLLAMA_KEEP_ALIVE=30m
# GUI: ⏏️ Eject model unloads VRAM (keep_alive=0); Shift+click ejects all loaded models
# AQUILA_WARMUP_ON_START=1
# AQUILA_COLD_START_EXTRA_SEC=90
# AQUILA_COLD_START_REQUESTS=3

# Character AI mode — in-character chat temperature (see docs/cai-mode.md)
# AQUILA_CHARACTER_TEMP=0.8
# AQUILA_LEARN_TUTOR_TEMP=0.7
# AQUILA_LEARN_ARCHIVE_TEMP=0.6
# Archive/course RAG: top-k passages and max injected chars (defaults 5 / 12000)
# AQUILA_LEARN_ARCHIVE_TOP_K=5
# AQUILA_LEARN_RETRIEVAL_MAX_CHARS=12000
# Archive chat: generation kill-switch seconds (0=off, use read timeout only; recommended for Qwen)
# AQUILA_LEARN_ARCHIVE_GENERATION_CAP=0
# Strip  blocks from streamed chat (default on)
# AQUILA_STRIP_THINK_STREAM=1
# Max tokens per chat reply (lower = faster on RAM offload; try 1024–1536 if sluggish)
# AQUILA_CHAT_NUM_PREDICT=2048
# Ollama read timeout scales with prompt size; raise cap for large contexts:
# AQUILA_READ_TIMEOUT_MAX=600

# Context / web enrichment (see ARCHITECTURE.md)
# AQUILA_AUTO_SCRAPE=1
# AQUILA_CONTEXT_TIER=standard|extended|max

# Prompt-size guardrails (recommended for 32k default)
# Cap individual tool outputs before they enter the conversation buffer
# AQUILA_TOOL_OUTPUT_CHAR_CAP=6000
# Enforce an overall per-turn prompt budget (step entry + summary + history + user msg)
# AQUILA_TOTAL_PROMPT_TOKEN_CAP=8000

# Aquila 3.4 — instances & context policy
# AQUILA_ACTIVE_INSTANCE=default
# AQUILA_CONVERSATION_ARCHIVE=1
# AQUILA_DIFF_REVIEW=1
# AQUILA_TERMINAL=0
# Pre-plan explore subagent (set 0 if you see JSON parse errors at task start)
# AQUILA_EXPLORE_BRIEF=1
# Per-step semantic tool routing (set 0 to always send full tool schema)
# AQUILA_ROUTE_TOOLS=1

# Structured output (Pydantic + Ollama json_schema — see docs/structured-output.md)
# AQUILA_STRUCTURED_STRICT=1
# AQUILA_STRUCTURED_NO_PLAIN=0
# AQUILA_SCHEMA_MAX_TOOLS=24

# Adaptive Ollama read timeouts (96k / long research — see ARCHITECTURE.md)
# AQUILA_READ_TIMEOUT_MAX=600
# AQUILA_TIMEOUT_PER_1K_TOKENS=5
# AQUILA_TIMEOUT_COMPRESS_RETRY=1

# Run logging: human .log (truncated) + JSONL events (default on)
# AQUILA_LOG_JSON=1
# AQUILA_LOG_FULL_TOOLS=0
